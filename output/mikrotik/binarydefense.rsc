# feed=binarydefense
:local listName "ti_out_binarydefense"
:local timeout "1d"
/ip firewall address-list
:do {
    :local addr "1.10.130.160/32"
    :local id [find where list=$listName and address=$addr]
    :if ([:len $id] > 0) do={
        set $id timeout=$timeout comment="TI binarydefense"
    } else={
        add list=$listName address=$addr timeout=$timeout comment="TI binarydefense"
    }
} on-error={ :log warning ("[TI] failed binarydefense " . "1.10.130.160/32") }
